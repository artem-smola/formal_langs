graph G {
  graph [labeljust="l", labelloc="t", fontsize=18, fontname="Arial", label="Chinese Postman: test1; sum=18, extra=0, total=18"];
  node [shape=circle, style=filled, fontname="Arial", fontsize=12, penwidth=1.5];
  edge [fontname="Arial", fontsize=11, color="#4b5563"];

  1 [fillcolor="#dbeafe", color="#1d4ed8", label="1"];
  2 [fillcolor="#dbeafe", color="#1d4ed8", label="2"];
  3 [fillcolor="#dbeafe", color="#1d4ed8", label="3"];
  4 [fillcolor="#dbeafe", color="#1d4ed8", label="4"];

  1 -- 2 [label="3", xlabel="e1"];
  2 -- 3 [label="4", xlabel="e2"];
  3 -- 4 [label="5", xlabel="e3"];
  4 -- 1 [label="6", xlabel="e4"];
}
