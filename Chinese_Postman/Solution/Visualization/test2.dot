graph G {
  graph [labeljust="l", labelloc="t", fontsize=18, fontname="Arial", label="Chinese Postman: test2; sum=5, extra=5, total=10; odd vertices: 1, 3"];
  node [shape=circle, style=filled, fontname="Arial", fontsize=12, penwidth=1.5];
  edge [fontname="Arial", fontsize=11, color="#4b5563"];

  1 [fillcolor="#fee2e2", color="#dc2626", label="1\nodd"];
  2 [fillcolor="#dbeafe", color="#1d4ed8", label="2"];
  3 [fillcolor="#fee2e2", color="#dc2626", label="3\nodd"];

  1 -- 2 [label="2", xlabel="e1"];
  2 -- 3 [label="3", xlabel="e2"];

  // Added shortest-path pairings for odd-degree vertices
  1 -- 3 [color="#dc2626", penwidth=2.4, style=dashed, label="+5", constraint=false];
}
