graph G {
  graph [labeljust="l", labelloc="t", fontsize=18, fontname="Arial", label="Chinese Postman: test3; sum=9, extra=2, total=11; odd vertices: 1, 2, 3, 5"];
  node [shape=circle, style=filled, fontname="Arial", fontsize=12, penwidth=1.5];
  edge [fontname="Arial", fontsize=11, color="#4b5563"];

  1 [fillcolor="#fee2e2", color="#dc2626", label="1\nodd"];
  2 [fillcolor="#fee2e2", color="#dc2626", label="2\nodd"];
  3 [fillcolor="#fee2e2", color="#dc2626", label="3\nodd"];
  4 [fillcolor="#dbeafe", color="#1d4ed8", label="4"];
  5 [fillcolor="#fee2e2", color="#dc2626", label="5\nodd"];

  1 -- 2 [label="1", xlabel="e1"];
  2 -- 3 [label="1", xlabel="e2"];
  3 -- 4 [label="1", xlabel="e3"];
  4 -- 5 [label="1", xlabel="e4"];
  5 -- 1 [label="1", xlabel="e5"];
  1 -- 3 [label="2", xlabel="e6"];
  2 -- 5 [label="2", xlabel="e7"];

  // Added shortest-path pairings for odd-degree vertices
  1 -- 5 [color="#dc2626", penwidth=2.4, style=dashed, label="+1", constraint=false];
  2 -- 3 [color="#dc2626", penwidth=2.4, style=dashed, label="+1", constraint=false];
}
