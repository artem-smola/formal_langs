digraph G {
  graph [labeljust="l", labelloc="t", fontsize=20, fontname="Arial", label="EFF rightmost derivations: test2"];
  rankdir=TB;
  node [shape=box, style=filled, fontname="Arial", fontsize=11, color="#374151"];
  edge [fontname="Arial", fontsize=10, color="#6b7280"];

  n0 [label="xS", fillcolor="#dbeafe", penwidth=2.0];
  n1 [label="xaA", fillcolor="#dbeafe", penwidth=1.2];
  n2 [label="xb", fillcolor="#bbf7d0", penwidth=1.2];
  n3 [label="xacD", fillcolor="#dbeafe", penwidth=1.2];
  n4 [label="xad", fillcolor="#bbf7d0", penwidth=1.2];
  n5 [label="xace", fillcolor="#bbf7d0", penwidth=1.2];
  n6 [label="xac", fillcolor="#bbf7d0", penwidth=1.2];

  n0 -> n1 [label="S->aA"];
  n0 -> n2 [label="S->b"];
  n1 -> n3 [label="A->cD"];
  n1 -> n4 [label="A->d"];
  n3 -> n5 [label="D->e"];
  n3 -> n6 [label="D->ε"];

  subgraph cluster_legend {
    label="Legend"; fontsize=13; fontname="Arial"; color="#d1d5db";
    key_nonterm [shape=box, style=filled, fillcolor="#dbeafe", label="sentential form"];
    key_eff [shape=box, style=filled, fillcolor="#bbf7d0", label="terminal leaf, prefix in EFF"];
    key_filtered [shape=box, style=filled, fillcolor="#e5e7eb", label="terminal leaf, filtered"];
    key_nonterm -> key_eff [style=invis];
    key_eff -> key_filtered [style=invis];
  }

  subgraph cluster_info {
    label="Test info"; fontsize=13; fontname="Arial"; color="#d1d5db";
    info_k [shape=note, label="k = 3"];
    info_alpha [shape=note, label="alpha = xS"];
    info_eff [shape=note, label="EFF = xac xad xb"];
    info_k -> info_alpha [style=invis];
    info_alpha -> info_eff [style=invis];
  }
}
