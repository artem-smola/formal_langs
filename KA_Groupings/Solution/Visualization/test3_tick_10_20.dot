graph G {
  graph [labeljust="l", labelloc="t", fontsize=18, fontname="Arial", label="KA Groupings: test3; tick [10, 20)"];
  node [shape=circle, style=filled, fontname="Arial", fontsize=11, penwidth=1.3];
  edge [fontname="Arial", fontsize=10];

  1 [label="1\nG1", fillcolor="#93c5fd", color="#1f2937"];
  2 [label="2\nG2", fillcolor="#86efac", color="#1f2937"];
  3 [label="3\nG3", fillcolor="#fca5a5", color="#1f2937"];
  4 [label="4\nG4", fillcolor="#fcd34d", color="#1f2937"];
  5 [label="5\nG4", fillcolor="#fcd34d", color="#1f2937"];
  6 [label="6\nG4", fillcolor="#fcd34d", color="#1f2937"];
  7 [label="7\nG4", fillcolor="#fcd34d", color="#1f2937"];

  1 -- 2 [label="10 [0,10]", xlabel="e1", color="#9ca3af", style=dashed];
  2 -- 3 [label="10 [0,10]", xlabel="e2", color="#9ca3af", style=dashed];
  3 -- 1 [label="10 [0,10]", xlabel="e3", color="#9ca3af", style=dashed];
  4 -- 5 [label="25 [0,25]", xlabel="e4", color="#0f172a", penwidth=2.0];
  5 -- 6 [label="10 [10,20]", xlabel="e5", color="#0f172a", penwidth=2.0];
  6 -- 7 [label="10 [15,25]", xlabel="e6", color="#0f172a", penwidth=2.0];
